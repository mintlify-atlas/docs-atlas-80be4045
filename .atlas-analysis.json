  "keyFeatures": [
    "Voice-to-text journaling with ElevenLabs Scribe AI transcription",
    "AI-powered text enhancement and cognitive analysis via Google Gemini",
    "Blockchain permanence with NFT minting on Base L2",
    "Local encrypted vault with AES-256-GCM client-side encryption",
    "Social feed with likes, tips, comments, and follower system",
    "Monetization through $STORY token rewards, paywalls, and NFT sales",
    "Chainlink CRE verifiable AI metrics with privacy-preserving on-chain proofs",
    "Dual authentication: Web3 wallet and Google OAuth with account linking"
  ],
  "publicApiSurface": [
    "POST /api/ai/transcribe - Convert audio to text",
    "POST /api/ai/enhance - AI text enhancement",
    "POST /api/ai/analyze - Extract cognitive metadata",
    "POST /api/journal/save - Save story entries",
    "POST /api/social/like - Like/unlike stories",
    "POST /api/social/follow - Follow/unfollow users",
    "POST /api/tip - Send $STORY token tips",
    "POST /api/paywall - Unlock paywalled content",
    "POST /api/book/compile - Compile stories into books",
    "GET /api/notifications - Fetch user notifications",
    "POST /api/cre/trigger - Trigger Chainlink CRE workflow",
    "useEStoryToken - ERC20 token balance and approve hooks",
    "useStoryProtocol - Tipping and paywall contract hooks",
    "useStoryNFT - NFT minting hooks",
    "useVerifiedMetrics - CRE-attested metrics polling",
    "useVault - Local encryption vault management",
    "useLocalStories - Encrypted IndexedDB CRUD operations"
  ]
